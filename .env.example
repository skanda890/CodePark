# Example Environment Variables

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=username
DB_PASSWORD=password
DB_NAME=database_name

# API Keys
API_KEY=your_api_key_here

# Email Configuration
EMAIL_USER=email@example.com
EMAIL_PASSWORD=password

# Debugging settings
debug_mode=False
